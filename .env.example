# Recruvault environment. Copy to .env.local and fill in.
# Generate secrets with: openssl rand -hex 32

# --- Core ---
DATABASE_URL=postgres://recruvault:recruvault@localhost:5432/recruvault
APP_URL=http://localhost:3000
# Session/signing secret for BetterAuth. Required.
BETTER_AUTH_SECRET=
# Optional dedicated secret for secure-link session cookies. Falls back to
# BETTER_AUTH_SECRET when unset.
LINK_SESSION_SECRET=
# Enabled in the local example so recruiter sign-up can be tested. Set false in
# production after the first owner uses /setup; job-seeker sign-up stays open.
ALLOW_RECRUITER_SIGNUP=true

# --- Encryption (envelope) ---
# Self-managed 256-bit master key that wraps every data key. Required in all
# environments. Generate with: openssl rand -hex 32
# Keep it secret and backed up — losing it makes all ciphertext unrecoverable.
LOCAL_KEK=
AWS_REGION=ap-southeast-2

# --- Object storage (S3 or MinIO) ---
AWS_ACCESS_KEY_ID=recruvault
AWS_SECRET_ACCESS_KEY=recruvault-secret
S3_BUCKET=recruvault-documents
# Point at MinIO for self-host, or leave unset to use real AWS S3.
S3_ENDPOINT=http://localhost:9000
S3_FORCE_PATH_STYLE=true
# Local MinIO needs a KMS before it can accept SSE-S3 uploads. Leave false for
# the bundled development stack; set true for configured providers.
S3_SERVER_SIDE_ENCRYPTION=false

# --- Virus scanning (ClamAV clamd) ---
CLAMAV_HOST=localhost
CLAMAV_PORT=3310
# Dev-only escape hatch; refuses to run when NODE_ENV=production.
SCAN_DISABLED=false

# --- Email (Resend) ---
# Without RESEND_API_KEY, emails are logged to the console instead of sent.
RESEND_API_KEY=
# Resend's test sender works locally but can send only to your Resend account
# email. For real recipients, use an address on a domain verified in Resend.
RESEND_FROM_EMAIL=onboarding@resend.dev
SHARED_SENDING_DOMAIN=mail.recruvault.example
# Required to accept Resend bounce/complaint webhooks (fail-closed without it).
RESEND_WEBHOOK_SECRET=

# --- SMS (AWS SNS), optional ---
SMS_ENABLED=false

# --- Observability ---
# Optional. When set, errors are reported to Sentry; unset = no-op.
SENTRY_DSN=
LOG_LEVEL=info

# --- Background jobs (Inngest) ---
# Local dev: set INNGEST_DEV=1 and run the Inngest dev server.
INNGEST_DEV=1
# Inngest Cloud (production): set these from your Inngest dashboard.
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
